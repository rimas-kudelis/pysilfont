<?xml version='1.0' encoding='utf-8'?>

<classes>

    <!-- Class that has typos (a.k.a. missing glyphs) -->
    <class name="hasTypos">
        LtnCapA LtnCCapB
    </class>

    <!-- Should match, including Graphite ordering === *NEXT 2 CLASSES MUST MATCH* ============ -->
    <class name="shouldMatch1">
        LtnCapA LtnCapE LtnCapI LtnCapO LtnCapU LtnCapY 
    </class>

    <class name="shouldMatch2">
        LtnSmA LtnSmE LtnSmI LtnSmO LtnSmU LtnSmY
    </class>

    <!-- Duplicate class definition =============================== -->
    <class name="shouldMatch2">
        LtnSmE LtnSmI LtnSmO LtnSmU LtnSmY
    </class>


    <!-- Length Mismatch === *NEXT 2 CLASSES MUST MATCH* ======== -->
    <class name="lengthMismatch1">
        LtnCapI LtnCapO LtnCapU LtnCapY 
    </class>

    <class name="lengthMismatch2">
        LtnSmI LtnSmO LtnSmU 
    </class>


    <!-- having some classes with fixed should generate warning but continue length checking --> 
    <!-- *NEXT 3 CLASSES MUST MATCH* -->
    <class name="notFixed1">
        LtnCapA LtnCapE LtnCapI LtnCapO LtnCapU LtnCapY 
    </class>

    <class name="fixed2" fixed="0">
        LtnSmA LtnSmE LtnSmI LtnSmO LtnSmU LtnSmY
    </class>

    <class name="notFixed3_lengthMismatch">
        LtnCapA LtnCapE LtnCapI LtnCapO LtnCapU  
    </class>

    <!-- Length Mismatch due to exts attribute === *NEXT 2 CLASSES MUST MATCH* ======== -->
    <class name="lengthMismatch5" exts=".alt">
        LtnCapA LtnCapI LtnCapO LtnCapU LtnCapY 
    </class>

    <class name="lengthMismatch6" exts=".alt">
        LtnSmA LtnSmI LtnSmO LtnSmU LtnCapY 
    </class>



    <!-- Graphite disordered === *NEXT 2 CLASSES MUST MATCH* ============= -->
    <class name="graphiteDisordered1">
        LtnCapA LtnCapE LtnCapI LtnCapO LtnCapU LtnCapY 
    </class>

    <class name="graphiteDisordered2">
        LtnSmE LtnSmA LtnSmI LtnSmO LtnSmU LtnSmY
    </class>

</classes>